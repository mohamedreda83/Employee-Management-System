@model Employee_Management_System.ViewModels.RoleManagement.RoleFormViewModel
@{
    ViewData["Title"] = "Create Role";
}

<div class="page-header" data-stagger-item>
    <div>
        <span class="page-eyebrow">Administration › Role Management</span>
        <h1>Create Role</h1>
        <p class="page-subtitle">Define a new role and configure its system access.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-lift">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div data-stagger-item>
    <partial name="_RoleForm" model="Model" />
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
