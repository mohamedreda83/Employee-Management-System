@model DepartmentFormViewModel
@{
    ViewData["Title"] = "Edit Department";
}

<div class="page-header" data-stagger-item>
    <div>
        <span class="page-eyebrow">Administration</span>
        <h1>Edit Department</h1>
        <p class="page-subtitle">Update the details for <strong>@Model.Name</strong>.</p>
    </div>
    <a asp-controller="Department" asp-action="Index" class="btn btn-outline-secondary btn-lift">
        <i class="bi bi-arrow-left"></i> Back to Departments
    </a>
</div>

<div class="row justify-content-center" data-stagger-item>
    <div class="col-lg-6">
        <div class="app-card">
            <div class="app-card-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle" style="background:var(--warning-bg);color:var(--warning);">
                        <i class="bi bi-pencil-fill"></i>
                    </div>
                    <h3 class="mb-0">Edit Details</h3>
                </div>
            </div>
            <div class="app-card-body">
                <form asp-controller="Department" asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    @await Html.PartialAsync("_DepartmentForm", Model)
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lift flex-grow-1">
                            <i class="bi bi-floppy me-1"></i> Save Changes
                        </button>
                        <a asp-controller="Department" asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Danger zone -->
        <div class="app-card mt-4" style="border:1px solid color-mix(in srgb, var(--danger) 30%, transparent);">
            <div class="app-card-header" style="border-bottom-color:color-mix(in srgb, var(--danger) 20%, transparent);">
                <div class="d-flex align-items-center gap-2" style="color:var(--danger);">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <h3 class="mb-0">Danger Zone</h3>
                </div>
            </div>
            <div class="app-card-body">
                <p style="font-size:13.5px; color:var(--text-secondary); margin-bottom:14px;">
                    Permanently delete this department. This action <strong>cannot be undone</strong>.
                    Departments with active employees cannot be deleted.
                </p>
                <form asp-controller="Department" asp-action="Delete" asp-route-id="@Model.Id"
                      method="post"
                      onsubmit="return confirm('Are you sure you want to delete \'@Model.Name\'? This cannot be undone.')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-lift btn-sm">
                        <i class="bi bi-trash3 me-1"></i> Delete Department
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
