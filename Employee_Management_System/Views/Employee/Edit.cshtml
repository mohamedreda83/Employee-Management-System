@model EmployeeEditViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="breadcrumb-mini" data-stagger-item>
    <a asp-controller="Employee" asp-action="Index">Employees</a>
    <i class="bi bi-chevron-right" style="font-size:9px;"></i>
    <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.Id">@Model.FullName</a>
    <i class="bi bi-chevron-right" style="font-size:9px;"></i>
    <span>Edit</span>
</div>

<div class="page-header" data-stagger-item>
    <div>
        <span class="page-eyebrow">Workforce</span>
        <h1>Edit Employee</h1>
        <p class="page-subtitle">Update @Model.FullName's information below.</p>
    </div>
</div>

<form asp-controller="Employee" asp-action="Edit" method="post" enctype="multipart/form-data" novalidate data-stagger-item>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="app-alert app-alert-danger mb-4" style="display:var(--validation-display, none);"></div>

    @{await Html.RenderPartialAsync("_EmployeeForm", Model);}
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
