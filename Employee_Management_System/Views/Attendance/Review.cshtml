@model AttendanceReviewViewModel
@{
    ViewData["Title"] = "Attendance Review";
    var hasFilteredResults = Model.AttendanceRecords != null && Model.AttendanceRecords.Any();
    var statusOptions = Model.StatusOptions != null && Model.StatusOptions.Any()
        ? Model.StatusOptions
        : new[] { "All", "Present", "Absent", "Late", "On Leave" };
}

<div class="page-header" data-stagger-item>
    <div>
        <span class="page-eyebrow">Workforce</span>
        <h1>Attendance Review</h1>
        <p class="page-subtitle">Review and manage daily attendance records across your organization.</p>
    </div>
    <a asp-controller="Attendance" asp-action="EmployeeAttendance" class="btn btn-outline-primary btn-lift">
        <i class="bi bi-person-check"></i> My Attendance
    </a>
</div>

<!-- Filter toolbar -->
<form asp-controller="Attendance" asp-action="ReviewFilter" method="post" class="filter-toolbar" data-stagger-item>
    @Html.AntiForgeryToken()
    <div class="row g-2 align-items-end">
        <div class="col-md-4 col-6">
            <label class="form-label">Date</label>
            <input type="date" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-4 col-6">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
                @foreach (var st in statusOptions)
                {
                    <option value="@st" selected="@(Model.StatusFilter == st ? "selected" : null)">@st</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary btn-lift w-100">
                <i class="bi bi-filter"></i> Apply Filter
            </button>
        </div>
    </div>
</form>

@if (!hasFilteredResults)
{
    <!-- Default employee directory state (initial GET) -->
    <div class="app-card" data-stagger-item>
        <div class="app-card-header">
            <h3>All Employees</h3>
            <span class="pill pill-info">@Model.Employees.Count() employees</span>
        </div>
        @if (!Model.Employees.Any())
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-people"></i></div>
                <h6>No employees found</h6>
                <p>Select a date and status above and apply the filter to review attendance records.</p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Position</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Model.Employees)
                        {
                            var empInitials = string.Join("", emp.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => p[0])).ToUpper();
                            <tr class="list-row-interactive">
                                <td>
                                    <div class="table-person">
                                        <div class="table-avatar">@empInitials</div>
                                        <div>
                                            <strong>@emp.FullName</strong>
                                            <span>#@emp.EmployeeNumber</span>
                                        </div>
                                    </div>
                                </td>
                                <td>@(emp.Department ?? "—")</td>
                                <td>@(emp.Position ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="app-card-body">
                <p class="form-text mb-0">Use the filter above to load attendance records for a specific date and status.</p>
            </div>
        }
    </div>
}
else
{
    <!-- Filtered attendance records state -->
    <div class="app-card" data-stagger-item>
        <div class="app-card-header">
            <h3>Attendance Records — @Model.Date.ToString("MMMM d, yyyy")</h3>
            <span class="pill pill-info">@Model.AttendanceRecords.Count() records</span>
        </div>
        <div class="table-wrap">
            <table class="app-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Status</th>
                        <th>Late / OT</th>
                        <th>Update</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rec in Model.AttendanceRecords)
                    {
                        var recInitials = string.Join("", rec.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => p[0])).ToUpper();
                        var pillClass = rec.Status switch
                        {
                            "Present" => "pill-success",
                            "Late" => "pill-warning",
                            "Absent" => "pill-danger",
                            "On Leave" => "pill-info",
                            _ => "pill-neutral"
                        };
                        <tr class="list-row-interactive">
                            <td>
                                <div class="table-person">
                                    <div class="table-avatar">@recInitials</div>
                                    <div>
                                        <strong>@rec.FullName</strong>
                                        <span>#@rec.EmployeeNumber</span>
                                    </div>
                                </div>
                            </td>
                            <td>@(rec.Department ?? "—")</td>
                            <td>@(rec.CheckInTime?.ToString("h:mm tt") ?? "—")</td>
                            <td>@(rec.CheckOutTime?.ToString("h:mm tt") ?? "—")</td>
                            <td><span class="pill @pillClass pill-glow">@(rec.Status ?? "—")</span></td>
                            <td style="font-size:12px; color:var(--text-tertiary);">
                                @(rec.LateMinutes > 0 ? $"Late {rec.LateMinutes}m" : "")
                                @(rec.OvertimeMinutes > 0 ? $" · OT {rec.OvertimeMinutes}m" : "")
                                @(rec.LateMinutes == 0 && rec.OvertimeMinutes == 0 ? "—" : "")
                            </td>
                            <td>
                                <button type="button" class="btn btn-outline-primary btn-sm btn-lift" data-bs-toggle="modal" data-bs-target="#updateAttendanceModal"
                                        data-att-id="@rec.AttendanceId" data-att-status="@rec.Status" data-att-reason="@rec.ManualReason" data-att-name="@rec.FullName">
                                    <i class="bi bi-pencil"></i> Update
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Update Attendance Modal -->
<div class="modal fade" id="updateAttendanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="Attendance" asp-action="UpdateAttendance" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Update Attendance</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="form-text mb-3">Editing record for <strong id="updateAttEmployeeName" style="color:var(--text-primary);"></strong></p>
                    <input type="hidden" name="id" id="updateAttId" />
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="status" id="updateAttStatus" class="form-select">
                            <option value="Present">Present</option>
                            <option value="Absent">Absent</option>
                            <option value="Late">Late</option>
                            <option value="On Leave">On Leave</option>
                        </select>
                    </div>
                    <div class="mb-1">
                        <label class="form-label">Manual Reason / Note</label>
                        <textarea name="manualReason" id="updateAttReason" class="form-control" rows="3" placeholder="Optional reason for manual override..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-primary btn-lift" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-lift"><i class="bi bi-check-lg"></i> Save Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('updateAttendanceModal').addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            document.getElementById('updateAttId').value = button.getAttribute('data-att-id') || '';
            document.getElementById('updateAttStatus').value = button.getAttribute('data-att-status') || 'Present';
            document.getElementById('updateAttReason').value = button.getAttribute('data-att-reason') || '';
            document.getElementById('updateAttEmployeeName').textContent = button.getAttribute('data-att-name') || '';
        });
    </script>
}
