@model EmployeeListItemViewModel

@{
    string pillClass = Model.EmploymentStatus switch
    {
        "Active" => "pill-success",
        "On Leave" => "pill-warning",
        "Inactive" => "pill-danger",
        _ => "pill-neutral"
    };
    string initials = string.Join("", Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(p => p[0])).ToUpper();
}

<div class="card-3d-wrap h-100">
    <div class="card-3d glass-solid h-100" data-tilt data-stagger-item>
        <div class="card-3d-shine"></div>
        <div class="card-3d-content app-card-body d-flex flex-column h-100">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
                    {
                        <img src="@Model.ProfilePhoto" alt="@Model.FullName" style="width:52px;height:52px;border-radius:50%;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="table-avatar" style="width:52px;height:52px;font-size:16px;">@initials</div>
                    }
                    <div>
                        <h6 class="mb-0" style="font-size:14.5px; color:var(--text-primary); font-weight:600;">@Model.FullName</h6>
                        <span style="font-size:11.5px; color:var(--text-tertiary);">#@Model.EmployeeNumber</span>
                    </div>
                </div>
                <div class="dropdown">
                    <button class="action-menu-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Employee" asp-action="Details" asp-route-id="@Model.Id"><i class="bi bi-eye"></i> View Details</a></li>
                        <li><a class="dropdown-item" asp-controller="Employee" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil"></i> Edit</a></li>
                    </ul>
                </div>
            </div>

            <div class="pill @pillClass pill-glow mb-3" style="align-self:flex-start;">@Model.EmploymentStatus</div>

            <div class="d-flex flex-column gap-2 mb-3" style="font-size:12.5px; color:var(--text-secondary);">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-briefcase" style="color:var(--text-tertiary); width:16px;"></i>
                    <span>@Model.Position · @Model.Department</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-envelope" style="color:var(--text-tertiary); width:16px;"></i>
                        <span class="text-truncate">@Model.Email</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-telephone" style="color:var(--text-tertiary); width:16px;"></i>
                        <span>@Model.Phone</span>
                    </div>
                }
            </div>

            <div class="mt-auto pt-2 d-flex gap-2">
                <a asp-controller="Employee" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm btn-lift flex-fill">
                    <i class="bi bi-eye"></i> View
                </a>
                <a asp-controller="Employee" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm btn-lift flex-fill">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
        </div>
    </div>
</div>
