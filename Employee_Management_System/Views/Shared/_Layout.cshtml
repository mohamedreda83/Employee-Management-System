@inject Microsoft.AspNetCore.Identity.SignInManager<Employee_Management_System.Models.ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<Employee_Management_System.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · NovaHR</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Lexend:wght@500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="ambient-blobs" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <div class="sidebar-backdrop" data-sidebar-toggle></div>

    <div class="app-shell">
        @await Html.PartialAsync("_Sidebar")

        <div class="app-main">
            @await Html.PartialAsync("_Topbar")

            <main class="page-content">
                @{
                    var statusMessage = TempData["StatusMessage"] as string;
                    var errorMessage = TempData["ErrorMessage"] as string;
                }
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="app-alert app-alert-success mb-4" data-auto-dismiss role="alert">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>@statusMessage</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="app-alert app-alert-danger mb-4" data-auto-dismiss role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div>@errorMessage</div>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="~/js/motion.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
