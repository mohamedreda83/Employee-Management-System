@model string
@{
    ViewData["Title"] = "Error";
    Layout = "_AuthLayout";
}

<span class="page-eyebrow">Error 500</span>
<h1 class="mb-2" style="font-size:26px;">Something went wrong</h1>
<p class="page-subtitle mb-4">An unexpected error occurred while processing your request. Please try again, and contact your system administrator if the problem persists.</p>

@if (!string.IsNullOrEmpty(Model))
{
    <div class="app-alert app-alert-danger mb-4">
        <i class="bi bi-bug-fill"></i>
        <div>Request ID: <code>@Model</code></div>
    </div>
}

<a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lift w-100">
    <i class="bi bi-house-door"></i> Back to Dashboard
</a>
