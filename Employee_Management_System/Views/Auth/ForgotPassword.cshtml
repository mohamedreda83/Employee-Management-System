@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<a asp-controller="Auth" asp-action="Login" class="breadcrumb-mini text-decoration-none mb-3 d-inline-flex">
    <i class="bi bi-arrow-left"></i> Back to Sign In
</a>

<span class="page-eyebrow">Account Recovery</span>
<h1 class="mb-2" style="font-size:26px;">Forgot your password?</h1>
<p class="page-subtitle mb-4">Enter the email address associated with your account and we'll send you a link to reset your password.</p>

<form asp-controller="Auth" asp-action="ForgotPassword" method="post" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="app-alert app-alert-danger mb-4" style="display:var(--validation-display, none);"></div>

    <div class="mb-4">
        <label asp-for="Email" class="form-label">Email Address <span class="required-dot">*</span></label>
        <div class="input-icon-group">
            <i class="bi bi-envelope"></i>
            <input asp-for="Email" class="form-control" placeholder="you@company.com" autocomplete="username" />
        </div>
        <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
    </div>

    <button type="submit" class="btn btn-primary btn-lg btn-lift w-100">
        <i class="bi bi-send"></i> Send Reset Link
    </button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
