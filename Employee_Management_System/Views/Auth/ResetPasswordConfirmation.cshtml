@{
    ViewData["Title"] = "Password Reset Complete";
    Layout = "_AuthLayout";
}

<div class="icon-circle mb-4" style="background:var(--success-bg); color:var(--success); width:64px; height:64px; font-size:26px;">
    <i class="bi bi-check-circle-fill"></i>
</div>

<span class="page-eyebrow">Success</span>
<h1 class="mb-2" style="font-size:26px;">Password reset complete</h1>
<p class="page-subtitle mb-4">
    Your password has been changed successfully. You can now sign in to NovaHR using your new password.
</p>

<a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lift w-100">
    <i class="bi bi-box-arrow-in-right"></i> Continue to Sign In
</a>
