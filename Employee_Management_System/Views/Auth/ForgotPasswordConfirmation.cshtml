@{
    ViewData["Title"] = "Check Your Email";
    Layout = "_AuthLayout";
}

<div class="icon-circle mb-4" style="background:var(--success-bg); color:var(--success); width:64px; height:64px; font-size:26px;">
    <i class="bi bi-envelope-check-fill"></i>
</div>

<span class="page-eyebrow">Almost there</span>
<h1 class="mb-2" style="font-size:26px;">Check your inbox</h1>
<p class="page-subtitle mb-4">
    If an account exists for the email you entered, we've sent a password reset link to it.
    Please check your inbox (and spam folder) for further instructions.
</p>

<a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lift w-100">
    <i class="bi bi-arrow-left"></i> Back to Sign In
</a>
