@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_AuthLayout";
}

<span class="page-eyebrow">Account Recovery</span>
<h1 class="mb-2" style="font-size:26px;">Set a new password</h1>
<p class="page-subtitle mb-4">Choose a strong password you haven't used before.</p>

<form asp-controller="Auth" asp-action="ResetPassword" method="post" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="app-alert app-alert-danger mb-4" style="display:var(--validation-display, none);"></div>

    <input type="hidden" asp-for="Code" />

    <div class="mb-3">
        <label asp-for="Email" class="form-label">Email Address <span class="required-dot">*</span></label>
        <div class="input-icon-group">
            <i class="bi bi-envelope"></i>
            <input asp-for="Email" class="form-control" placeholder="you@company.com" autocomplete="username" />
        </div>
        <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">New Password <span class="required-dot">*</span></label>
        <div class="input-icon-group">
            <i class="bi bi-lock"></i>
            <input asp-for="Password" type="password" class="form-control" placeholder="At least 6 characters" id="newPassword" autocomplete="new-password" />
            <button type="button" class="toggle-password" data-target="newPassword" aria-label="Toggle password visibility">
                <i class="bi bi-eye"></i>
            </button>
        </div>
        <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
    </div>

    <div class="mb-4">
        <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="required-dot">*</span></label>
        <div class="input-icon-group">
            <i class="bi bi-lock-fill"></i>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter password" id="confirmPassword" autocomplete="new-password" />
            <button type="button" class="toggle-password" data-target="confirmPassword" aria-label="Toggle password visibility">
                <i class="bi bi-eye"></i>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></span>
    </div>

    <button type="submit" class="btn btn-primary btn-lg btn-lift w-100">
        <i class="bi bi-shield-check"></i> Reset Password
    </button>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
