@model CreateUserViewModel
@using Employee_Management_System.ViewModels.UserManagement
@{
    ViewData["Title"] = "Create Account";
}

<div class="page-header" data-stagger-item>
    <div>
        <span class="page-eyebrow">Administration › User Management</span>
        <h1>Create Account</h1>
        <p class="page-subtitle">Set up a system login for <strong>@Model.EmployeeName</strong>.</p>
    </div>
    <a asp-controller="UserManagement" asp-action="Index" class="btn btn-outline-secondary btn-lift">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div class="row justify-content-center" data-stagger-item>
    <div class="col-lg-6">

        <!-- Employee info banner -->
        <div class="app-card mb-4" style="border-left:4px solid var(--primary);">
            <div class="app-card-body d-flex align-items-center gap-3">
                <div class="icon-circle" style="background:var(--info-bg);color:var(--secondary);flex-shrink:0;">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
                <div>
                    <strong style="font-size:15px;">@Model.EmployeeName</strong>
                    <div style="font-size:12.5px;color:var(--text-tertiary);">Employee #@Model.EmployeeNumber</div>
                </div>
            </div>
        </div>

        <div class="app-card">
            <div class="app-card-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle" style="background:var(--success-bg);color:var(--success);">
                        <i class="bi bi-shield-plus-fill"></i>
                    </div>
                    <h3 class="mb-0">Account Credentials</h3>
                </div>
            </div>
            <div class="app-card-body">
                <form asp-controller="UserManagement" asp-action="Create" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="EmployeeId" />
                    <input type="hidden" asp-for="EmployeeName" />
                    <input type="hidden" asp-for="EmployeeNumber" />

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email / Username <span class="required-dot">*</span></label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="employee@company.com" />
                        <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password <span class="required-dot">*</span></label>
                        <div class="input-icon-group">
                            <i class="bi bi-key-fill"></i>
                            <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters" id="pwd" />
                        </div>
                        <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="required-dot">*</span></label>
                        <div class="input-icon-group">
                            <i class="bi bi-key-fill"></i>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></span>
                    </div>

                    <!-- Roles -->
                    <div class="mb-4">
                        <label class="form-label">Assign Roles</label>
                        <div class="d-flex flex-wrap gap-3 pt-1">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                var roleIcon = role switch { "Admin" => "bi-shield-fill-exclamation", "HR" => "bi-person-badge-fill", _ => "bi-person-fill" };
                                var roleColor = role switch { "Admin" => "var(--danger)", "HR" => "var(--warning)", _ => "var(--secondary)" };
                                <label class="role-check-label" style="--rc:@roleColor">
                                    <input type="checkbox" name="SelectedRoles" value="@role"
                                           @(Model.SelectedRoles.Contains(role) ? "checked" : "") />
                                    <span class="role-check-box">
                                        <i class="bi @roleIcon"></i>
                                        @role
                                    </span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lift flex-grow-1">
                            <i class="bi bi-shield-plus me-1"></i> Create Account
                        </button>
                        <a asp-controller="UserManagement" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
.role-check-label { cursor:pointer; }
.role-check-label input[type=checkbox] { display:none; }
.role-check-box {
    display:inline-flex; align-items:center; gap:6px;
    padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600;
    border:2px solid var(--border);
    color:var(--text-secondary);
    transition:all 0.18s;
    user-select:none;
}
.role-check-label input:checked + .role-check-box {
    background:color-mix(in srgb, var(--rc) 12%, transparent);
    border-color:var(--rc);
    color:var(--rc);
}
.role-check-box:hover { border-color:var(--rc); }
</style>
