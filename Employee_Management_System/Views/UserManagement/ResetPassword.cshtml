@model ResetPasswordAdminViewModel
@using Employee_Management_System.ViewModels.UserManagement
@{
    ViewData["Title"] = "Reset Password";
}

<div class="page-header" data-stagger-item>
    <div>
        <span class="page-eyebrow">Administration › User Management</span>
        <h1>Reset Password</h1>
        <p class="page-subtitle">Force a password reset for <strong>@Model.EmployeeName</strong>.</p>
    </div>
    <a asp-controller="UserManagement" asp-action="Index" class="btn btn-outline-secondary btn-lift">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div class="row justify-content-center" data-stagger-item>
    <div class="col-lg-5">

        <div class="app-card mb-4">
            <div class="app-card-body d-flex align-items-center gap-3">
                <div class="icon-circle" style="background:var(--danger-bg);color:var(--danger);flex-shrink:0;">
                    <i class="bi bi-key-fill"></i>
                </div>
                <div>
                    <strong style="font-size:15px;">@Model.EmployeeName</strong>
                    <div style="font-size:12.5px;color:var(--text-tertiary);">@Model.Email</div>
                </div>
            </div>
        </div>

        <div class="app-card">
            <div class="app-card-body">
                <form asp-controller="UserManagement" asp-action="ResetPassword" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="EmployeeName" />

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New Password <span class="required-dot">*</span></label>
                        <div class="input-icon-group">
                            <i class="bi bi-key-fill"></i>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="Min. 6 characters" />
                        </div>
                        <span asp-validation-for="NewPassword" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="required-dot">*</span></label>
                        <div class="input-icon-group">
                            <i class="bi bi-key-fill"></i>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat new password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="invalid-feedback d-block"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger btn-lift flex-grow-1">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Reset Password
                        </button>
                        <a asp-controller="UserManagement" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
