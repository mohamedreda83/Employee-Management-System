@model PositionFormViewModel
@using Employee_Management_System.ViewModels.Position
@{
    ViewData["Title"] = "New Position";
}

<div class="page-header" data-stagger-item>
    <div>
        <span class="page-eyebrow">Administration</span>
        <h1>New Position</h1>
        <p class="page-subtitle">Define a new job position in your organisation.</p>
    </div>
    <a asp-controller="Position" asp-action="Index" class="btn btn-outline-secondary btn-lift">
        <i class="bi bi-arrow-left"></i> Back to Positions
    </a>
</div>

<div class="row justify-content-center" data-stagger-item>
    <div class="col-lg-6">
        <div class="app-card">
            <div class="app-card-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle" style="background:var(--info-bg);color:var(--secondary);">
                        <i class="bi bi-briefcase-fill"></i>
                    </div>
                    <h3 class="mb-0">Position Details</h3>
                </div>
            </div>
            <div class="app-card-body">
                <form asp-controller="Position" asp-action="Create" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    @await Html.PartialAsync("_PositionForm", Model)
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lift flex-grow-1">
                            <i class="bi bi-plus-lg me-1"></i> Create Position
                        </button>
                        <a asp-controller="Position" asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
